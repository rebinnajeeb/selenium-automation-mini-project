    @Parameters({"browser"})
    @BeforeClass
    public void setup(String browser) {
        browserName = browser.toLowerCase();

        if (browserName.equals("chrome")) {
            driver.set(new ChromeDriver());
        } else if (browserName.equals("firefox")) {
            driver.set(new FirefoxDriver());
        } else if (browserName.equals("edge")) {
            System.setProperty("webdriver.edge.driver", "C:\\Users\\2403682\\Downloads\\edgedriver_win64\\msedgedriver.exe");
            driver.set(new org.openqa.selenium.edge.EdgeDriver());
        } else {
            throw new IllegalArgumentException("Invalid browser: " + browser);
        }
        driver.get().manage().window().maximize();
        
    }
    
    @Test(priority = 1)
    public void searchForBook() {
        WebDriver d = driver.get();
        d.get("https://www.bookswagon.com/");
        WebElement searchbar = d.findElement(By.id("inputbar"));
        searchbar.sendKeys("Selenium Webdriver");
        d.findElement(By.id("btnTopSearch")).click();
        System.out.println(" Search performed for 'Selenium Webdriver'.");
    }

    @Test(priority = 2)
    public void checkSearchResults() {
        WebDriver d = driver.get();
        WebElement number = d.findElement(By.xpath("//div[@class='preferences-show']/b"));
        String text = number.getText();
        int num = Integer.parseInt(text);
        
        Assert.assertTrue(num > 10);
        System.out.println("SUCCESS: More than 10 results were found. Found: " + num);
    }

    @Test(priority = 3)
    public void sortResults() {
        WebDriver d = driver.get();
        WebElement sort = d.findElement(By.id("ddlSort"));
        Select select = new Select(sort);
        sleep(3000);
        select.selectByVisibleText("Price - Low to High");
        sleep(3000);
        System.out.println("Results sorted by Price - Low to High.");
        WebElement check=d.findElement(By.xpath("//*[@id=\"ddlSort\"]/option[5]"));
        String checktext=check.getText();
		Assert.assertEquals(checktext,"Price - Low to High");
    }

    @Test(priority = 4)
    public void getAndPrintResults() {
        WebDriver d = driver.get();
        
        t1 = d.findElement(By.xpath("//*[@id=\"listSearchResult\"]/div[1]/div[3]/div[1]/a")).getText();
        p1 = d.findElement(By.xpath("//*[@id=\"listSearchResult\"]/div[1]/div[3]/div[5]/div[1]/div")).getText();
        
        t2 = d.findElement(By.xpath("//*[@id=\"listSearchResult\"]/div[2]/div[3]/div[1]/a")).getText();
        p2 = d.findElement(By.xpath("//*[@id=\"listSearchResult\"]/div[2]/div[3]/div[5]/div[1]/div[2]")).getText();
        
        t3 = d.findElement(By.xpath("//*[@id=\"listSearchResult\"]/div[3]/div[3]/div[1]/a")).getText();
        p3 = d.findElement(By.xpath("//*[@id=\"listSearchResult\"]/div[3]/div[3]/div[5]/div[1]/div[2]")).getText();
        
        t4 = d.findElement(By.xpath("//*[@id=\"listSearchResult\"]/div[4]/div[3]/div[1]/a")).getText();
        p4 = d.findElement(By.xpath("//*[@id=\"listSearchResult\"]/div[4]/div[3]/div[5]/div[1]/div[2]")).getText();
        
        t5 = d.findElement(By.xpath("//*[@id=\"listSearchResult\"]/div[5]/div[3]/div[1]/a")).getText();
        p5 = d.findElement(By.xpath("//*[@id=\"listSearchResult\"]/div[5]/div[3]/div[5]/div[1]/div[2]")).getText();
        
        System.out.println("\n📚 Top 5 Search Results (Sorted Low to High):");
        System.out.println("1. " + t1 + " - " + p1);
        System.out.println("2. " + t2 + " - " + p2);
        System.out.println("3. " + t3 + " - " + p3);
        System.out.println("4. " + t4 + " - " + p4);
        System.out.println("5. " + t5 + " - " + p5);
       
    }
